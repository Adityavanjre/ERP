generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String       @id @default(uuid())
  email                String       @unique
  passwordHash         String?
  fullName             String?
  avatarUrl            String?
  authProvider         AuthProvider @default(Email)
  providerId           String? // e.g., Google ID
  isSuperAdmin         Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // MFA & Security Hardening
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String? // Encrypted TOTP secret
  mfaRecoveryCodes    String[] // Hashed recovery codes
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  tokenVersion        Int       @default(1)

  auditLogs             AuditLog[]
  memberships           TenantUser[]
  productsCreated       Product[]      @relation("ProductCreator")
  productsUpdated       Product[]      @relation("ProductUpdater")
  journalEntriesCreated JournalEntry[] @relation("JournalCreator")
}

model Tenant {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  type         TenantType @default(Retail)
  industry     String?
  businessType String?
  isOnboarded  Boolean    @default(false)
  plan         PlanType   @default(Free)
  logoUrl      String?
  address      String?
  state        String?
  gstin        String?
  fyStartMonth Int        @default(4)
  fyStartDay   Int        @default(1)
  currency     String     @default("INR")

  // Subscription lifecycle
  subscriptionStatus SubscriptionStatus @default(Active)
  planExpiresAt      DateTime? // When current paid period ends
  gracePeriodEndsAt  DateTime? // 14-day payment overdue window
  suspendedAt        DateTime? // Timestamp of suspension
  suspendReason      String? // non-payment | abuse | admin

  // Razorpay Integration (SUB-002)
  razorpayCustomerId     String?
  razorpaySubscriptionId String?

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  auditLogs               AuditLog[]
  boms                    BillOfMaterial[]
  customers               Customer[]
  openingBalances         CustomerOpeningBalance[]
  departments             Department[]
  employees               Employee[]
  invoices                Invoice[]
  journalEntries          JournalEntry[]
  machines                Machine[]
  opportunities           Opportunity[]
  orders                  Order[]
  payments                Payment[]
  periodLocks             PeriodLock[]
  products                Product[]
  projects                Project[]
  purchaseOrders          PurchaseOrder[]
  suppliers               Supplier[]
  supplierOpeningBalances SupplierOpeningBalance[]
  tasks                   Task[]
  users                   TenantUser[]
  transactions            Transaction[]
  workOrders              WorkOrder[]
  records                 Record[]
  warehouses              Warehouse[]
  stockMovements          StockMovement[]
  fixedAssets             FixedAsset[]
  comments                Comment[]
  apiKeys                 ApiKey[]
  creditNotes             CreditNote[]
  debitNotes              DebitNote[]
  payrolls                Payroll[]
  leaves                  Leave[]
  invoiceItems            InvoiceItem[]
  poItems                 PurchaseOrderItem[]
  bomItems                BOMItem[]
  stockLocations          StockLocation[]
  cnItems                 CreditNoteItem[]
  dnItems                 DebitNoteItem[]
  warehousePrices         WarehousePrice[]
  tdsRules                TdsRule[]
  tdsLedgerMappings       TdsLedgerMapping[]
  tdsTransactions         TdsTransaction[]
  retentionSchedules      RetentionSchedule[]
  routeBenchmarks         RouteBenchmark[]
  loanInterestSlabs       LoanInterestSlab[]

  // Healthcare
  patients        Patient[]
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  pharmacyBatches PharmacyBatch[]

  // Construction
  boqs            BOQ[]
  boqItems        BOQItem[]
  siteInventories SiteInventory[]

  // Logistics
  vehicles             Vehicle[]
  fuelLogs             FuelLog[]
  routeLogs            RouteLog[]
  maintenanceSchedules MaintenanceSchedule[]

  // NBFC
  loans               Loan[]
  emiSchedules        EMISchedule[]
  interestAccruals    InterestAccrual[]
  kycRecords          KYCRecord[]
  bankStatements      BankStatement[]
  bankStatementLines  BankStatementLine[]
  bankReconciliations BankReconciliation[]
  hsnMasters          HsnMaster[]
}

model PeriodLock {
  id           String    @id @default(uuid())
  tenantId     String
  month        Int
  year         Int
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  reopenedAt   DateTime?
  reopenReason String?
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month, year])
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     Role   @default(Biller)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Product {
  id                 String              @id @default(uuid())
  tenantId           String
  name               String
  sku                String
  description        String?
  price              Decimal             @default(0.00)
  costPrice          Decimal             @default(0.00)
  stock              Decimal             @default(0.00)
  category           String?
  tags               String?
  brand              String?
  manufacturer       String?
  weight             String?
  dimensions         String?
  minStockLevel      Decimal             @default(0.00)
  supplierName       String?
  isService          Boolean             @default(false)
  hsnCode            String?
  gstRate            Decimal             @default(0.00)
  isGstOverride      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  isDeleted          Boolean             @default(false)
  barcode            String?
  skuAlias           String?
  shelfLifeDays      Int? // Retail Depth: Aging/Markdown
  bomAsMaterial      BOMItem[]
  bomAsFinished      BillOfMaterial[]
  invoiceItems       InvoiceItem[]
  orderItems         OrderItem[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  createdBy          User?               @relation("ProductCreator", fields: [createdById], references: [id])
  updatedBy          User?               @relation("ProductUpdater", fields: [updatedById], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  stockLocations     StockLocation[]
  stockMovements     StockMovement[]
  creditNoteItems    CreditNoteItem[]
  debitNoteItems     DebitNoteItem[]
  pharmacyBatches    PharmacyBatch[]
  siteInventories    SiteInventory[]
  warehousePrices    WarehousePrice[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, category])
  @@index([tenantId, tags])
  @@index([tenantId, brand])
  @@index([tenantId, skuAlias])
  @@index([tenantId, hsnCode])
}

model Customer {
  id              String                   @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  company         String?
  address         String?
  state           String?
  gstin           String?
  status          CustomerStatus           @default(Lead)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  isDeleted       Boolean                  @default(false)
  userId          String?                  @unique
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances CustomerOpeningBalance[]
  invoices        Invoice[]
  opportunities   Opportunity[]
  projects        Project[]
  orders          Order[]
  payments        Payment[]
  creditNotes     CreditNote[]
  patient         Patient?
  loans           Loan[]

  @@index([tenantId, email])
  @@index([tenantId, company])
  @@index([tenantId, status])
  @@index([tenantId, phone])
  @@index([tenantId, firstName, lastName])
}

model Opportunity {
  id            String    @id @default(uuid())
  tenantId      String
  title         String
  value         Decimal   @default(0.00)
  stage         Stage     @default(New)
  probability   Int       @default(0)
  expectedClose DateTime?
  customerId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  customer      Customer  @relation(fields: [customerId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String?
  total          Decimal     @default(0.00)
  status         OrderStatus @default(Draft)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  customer       Customer?   @relation(fields: [customerId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  items          OrderItem[]
  idempotencyKey String?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([tenantId, customerId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Decimal
  price     Decimal
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])

  @@index([orderId, productId])
}

model AuditLog {
  id             String   @id @default(uuid())
  tenantId       String?
  userId         String?
  action         String
  resource       String
  details        Json?
  channel        String?
  ipAddress      String?
  correlationId  String?  @default(uuid())
  responseTimeMs Int?
  createdAt      DateTime @default(now())

  // Hash chain for tamper-evidence (Phase 2 — Audit Forensics)
  // prevHash: entryHash of the immediately preceding AuditLog entry for this tenant.
  //           NULL only for a tenant's very first entry.
  // entryHash: HMAC-SHA256(prevHash + action + resource + createdAt + details, AUDIT_HMAC_SECRET)
  //            A divergence here proves the chain was tampered with.
  prevHash  String? // Hash of the previous entry in the tenant's chain
  entryHash String? // HMAC-SHA256 of this entry's canonical fields

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([correlationId])
  @@index([action])
}

model BillOfMaterial {
  id              String      @id @default(uuid())
  tenantId        String
  name            String
  productId       String
  quantity        Int         @default(1)
  overheadRate    Decimal     @default(0.00)
  isOverheadFixed Boolean     @default(false)
  status          BOMStatus   @default(Active)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           BOMItem[]
  product         Product     @relation(fields: [productId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  workOrders      WorkOrder[]
  correlationId   String?

  @@index([correlationId])
}

model BOMItem {
  id          String         @id @default(uuid())
  tenantId    String
  bomId       String
  productId   String
  quantity    Decimal
  unit        String?
  isByproduct Boolean        @default(false)
  product     Product        @relation(fields: [productId], references: [id])
  bom         BillOfMaterial @relation(fields: [bomId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model WorkOrder {
  id               String          @id @default(uuid())
  tenantId         String
  orderNumber      String
  bomId            String
  quantity         Decimal
  producedQuantity Decimal         @default(0.00)
  scrapQuantity    Decimal         @default(0.00)
  machineId        String?
  machineTimeHours Float?
  operatorName     String?
  startDate        DateTime?
  endDate          DateTime?
  status           WorkOrderStatus @default(Planned)
  priority         Priority        @default(Medium)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  idempotencyKey   String?
  correlationId    String?
  completionLog    Json?
  bom              BillOfMaterial  @relation(fields: [bomId], references: [id])
  machine          Machine?        @relation(fields: [machineId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, orderNumber])
  @@index([tenantId, status, startDate])
  @@index([correlationId])
}

model Machine {
  id              String        @id @default(uuid())
  tenantId        String
  name            String
  code            String
  type            String?
  status          MachineStatus @default(Idle)
  hourlyRate      Decimal?      @default(0.00)
  lastMaintenance DateTime?
  createdAt       DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  workOrders      WorkOrder[]
}

model Account {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  code              String
  type              AccountType
  balance           Decimal            @default(0.00)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  transactions      Transaction[]
  tdsLedgerMappings TdsLedgerMapping[]
  bankStatements    BankStatement[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
}

model JournalEntry {
  id              String           @id @default(uuid())
  tenantId        String
  date            DateTime         @default(now())
  description     String
  reference       String?
  correlationId   String?
  posted          Boolean          @default(false)
  createdById     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  createdBy       User?            @relation("JournalCreator", fields: [createdById], references: [id])
  transactions    Transaction[]
  invoice         Invoice?         @relation("InvoiceJournal")
  creditNote      CreditNote?      @relation("CreditNoteJournal")
  debitNote       DebitNote?       @relation("DebitNoteJournal")
  tdsTransaction  TdsTransaction?
  fuelLog         FuelLog?
  loan            Loan?
  interestAccrual InterestAccrual?

  @@index([tenantId, date])
  @@index([correlationId])
  @@index([reference])
}

model Transaction {
  id              String               @id @default(uuid())
  tenantId        String
  date            DateTime             @default(now())
  description     String
  amount          Decimal
  type            TransactionType
  accountId       String
  journalEntryId  String?
  correlationId   String?
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account         Account              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  reconciliations BankReconciliation[]

  @@index([tenantId, date])
  @@index([accountId])
  @@index([journalEntryId])
  @@index([correlationId])
  @@index([tenantId, accountId, date])
}

model Invoice {
  id                 String        @id @default(uuid())
  tenantId           String
  customerId         String?
  invoiceNumber      String
  issueDate          DateTime      @default(now())
  dueDate            DateTime
  totalAmount        Decimal
  amountPaid         Decimal       @default(0.00)
  totalTaxable       Decimal       @default(0.00)
  totalGST           Decimal       @default(0.00)
  totalCGST          Decimal       @default(0.00)
  totalSGST          Decimal       @default(0.00)
  totalIGST          Decimal       @default(0.00)
  status             InvoiceStatus @default(Unpaid)
  billingTimeSeconds Int?
  isLocked           Boolean       @default(false)
  idempotencyKey     String?
  correlationId      String?
  tallyExported      Boolean       @default(false)
  cancellationReason String?
  isInterState       Boolean?      @default(false)
  journalEntryId     String?       @unique
  journalEntry       JournalEntry? @relation("InvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  customer           Customer?     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  creditNotes        CreditNote[]
  items              InvoiceItem[]
  payments           Payment[]

  @@unique([tenantId, invoiceNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, issueDate])
  @@index([tenantId, status])
  @@index([correlationId])
  @@index([invoiceNumber])
  @@index([projectId])
  @@index([tenantId, status, issueDate])
}

model InvoiceItem {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  productId     String
  productName   String   @default("")
  hsnCode       String?
  quantity      Decimal
  unitPrice     Decimal
  gstRate       Decimal
  isGstOverride Boolean  @default(false)
  taxableAmount Decimal
  gstAmount     Decimal
  cgstAmount    Decimal  @default(0.00)
  sgstAmount    Decimal  @default(0.00)
  igstAmount    Decimal  @default(0.00)
  totalAmount   Decimal
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([invoiceId, productId])
  @@index([tenantId])
}

model Payment {
  id             String          @id @default(uuid())
  tenantId       String
  customerId     String?
  supplierId     String?
  invoiceId      String?
  amount         Decimal
  tdsAmount      Decimal?        @default(0.00)
  netAmount      Decimal?        @default(0.00)
  tdsSection     String?
  date           DateTime        @default(now())
  mode           PaymentMode     @default(Cash)
  reference      String?
  notes          String?
  correlationId  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isLocked       Boolean         @default(false)
  idempotencyKey String?
  tallyExported  Boolean         @default(false)
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tdsTransaction TdsTransaction?
  emiSchedule    EMISchedule?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, date])
  @@index([tenantId, customerId, date])
  @@index([correlationId])
}

model CustomerOpeningBalance {
  id            String   @id @default(uuid())
  tenantId      String
  customerId    String
  amount        Decimal
  date          DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  customer      Customer @relation(fields: [customerId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  correlationId String?

  @@index([tenantId, customerId])
  @@index([correlationId])
}

model Employee {
  id           String         @id @default(uuid())
  tenantId     String
  userId       String?        @unique
  employeeId   String
  firstName    String
  lastName     String
  email        String
  phone        String?
  jobTitle     String
  departmentId String?
  salary       Decimal        @default(0.00)
  joiningDate  DateTime       @default(now())
  status       EmployeeStatus @default(Active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  department   Department?    @relation(fields: [departmentId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  leaves       Leave[]
  payrolls     Payroll[]
  appointments Appointment[]

  @@unique([tenantId, employeeId])
}

model Department {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  managerId String?
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]
}

model Payroll {
  id          String        @id @default(uuid())
  tenantId    String
  employeeId  String
  periodStart DateTime
  periodEnd   DateTime
  basicSalary Decimal
  bonuses     Decimal       @default(0.00)
  deductions  Decimal       @default(0.00)
  netPay      Decimal
  status      PayrollStatus @default(Draft)
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  employee    Employee      @relation(fields: [employeeId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  // DB-level idempotency: prevents duplicate salary disbursement for the same employee and period.
  // This is the hard guarantee behind the application-layer check in hr.service.ts.
  @@unique([employeeId, periodStart, periodEnd])
  @@index([tenantId, createdAt])
}

model Leave {
  id         String      @id @default(uuid())
  tenantId   String
  employeeId String
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(Pending)
  createdAt  DateTime    @default(now())
  employee   Employee    @relation(fields: [employeeId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model Supplier {
  id                String                   @id @default(uuid())
  tenantId          String
  name              String
  contactName       String?
  email             String
  phone             String?
  address           String?
  state             String?
  gstin             String?
  category          String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  isDeleted         Boolean                  @default(false)
  userId            String?                  @unique
  pan               String?
  vendorType        VendorType               @default(Individual)
  defaultTdsSection String?
  payments          Payment[]
  purchaseOrders    PurchaseOrder[]
  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances   SupplierOpeningBalance[]
  debitNotes        DebitNote[]
  tdsTransactions   TdsTransaction[]
}

enum VendorType {
  Company
  Individual
}

model SupplierOpeningBalance {
  id            String   @id @default(uuid())
  tenantId      String
  supplierId    String
  amount        Decimal
  date          DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  correlationId String?

  @@index([tenantId, supplierId])
  @@index([correlationId])
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  tenantId       String
  supplierId     String
  orderNumber    String
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  totalAmount    Decimal
  totalTaxable   Decimal             @default(0.00)
  totalGST       Decimal             @default(0.00)
  totalCGST      Decimal             @default(0.00)
  totalSGST      Decimal             @default(0.00)
  totalIGST      Decimal             @default(0.00)
  tdsAmount      Decimal?            @default(0.00)
  netAmount      Decimal?            @default(0.00)
  tdsSection     String?
  status         POStatus            @default(Draft)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  idempotencyKey String?
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items          PurchaseOrderItem[]
  debitNotes     DebitNote[]
  tdsTransaction TdsTransaction?

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, orderNumber])
  @@index([tenantId, status, expectedDate])
  @@index([tenantId, supplierId, orderDate])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  tenantId        String
  purchaseOrderId String
  productId       String
  hsnCode         String?
  quantity        Decimal
  unitPrice       Decimal
  taxableAmount   Decimal       @default(0.00)
  gstRate         Decimal       @default(0.00)
  cgstAmount      Decimal       @default(0.00)
  sgstAmount      Decimal       @default(0.00)
  igstAmount      Decimal       @default(0.00)
  totalAmount     Decimal       @default(0.00)
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderId, productId])
  @@index([tenantId])
}

model CreditNote {
  id             String           @id @default(uuid())
  tenantId       String
  customerId     String
  invoiceId      String?
  noteNumber     String
  date           DateTime         @default(now())
  totalAmount    Decimal
  totalTaxable   Decimal          @default(0.00)
  totalGST       Decimal          @default(0.00)
  totalCGST      Decimal          @default(0.00)
  totalSGST      Decimal          @default(0.00)
  totalIGST      Decimal          @default(0.00)
  reason         String?
  journalEntryId String?          @unique
  correlationId  String?
  journalEntry   JournalEntry?    @relation("CreditNoteJournal", fields: [journalEntryId], references: [id])
  invoice        Invoice?         @relation(fields: [invoiceId], references: [id])
  customer       Customer         @relation(fields: [customerId], references: [id])
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  idempotencyKey String?
  items          CreditNoteItem[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, noteNumber])
  @@index([tenantId, customerId])
  @@index([correlationId])
}

