model FixedAsset {
  id                      String            @id @default(uuid())
  tenantId                String
  name                    String
  assetCode               String
  purchaseDate            DateTime
  purchaseValue           Decimal
  salvageValue            Decimal           @default(0.00)
  usefulLife              Int // in months
  accumulatedDepreciation Decimal           @default(0.00)
  status                  AssetStatus       @default(Active)
  idempotencyKey          String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  tenant                  Tenant            @relation(fields: [tenantId], references: [id])
  depreciationLogs        DepreciationLog[]
  correlationId           String?

  @@unique([tenantId, assetCode])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([correlationId])
}

model DepreciationLog {
  id             String     @id @default(uuid())
  tenantId       String
  assetId        String
  amount         Decimal
  date           DateTime   @default(now())
  description    String?
  journalEntryId String?    @unique
  asset          FixedAsset @relation(fields: [assetId], references: [id])
  createdAt      DateTime   @default(now())

  @@index([tenantId, assetId])
}

enum AssetStatus {
  Active
  Disposed
  FullyDepreciated
}

model Comment {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  content      String
  parentId     String? // For threaded replies
  resourceType String // e.g., 'Invoice', 'Project', 'Task', 'BillOfMaterials'
  resourceId   String // The ID of the specific resource
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant    @relation(fields: [tenantId], references: [id])
  parent  Comment?  @relation("ThreadedComments", fields: [parentId], references: [id])
  replies Comment[] @relation("ThreadedComments")

  @@index([tenantId])
  @@index([resourceType, resourceId])
}

model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  key        String    @unique // Hashed key
  prefix     String // First segment for identification
  scopes     Json      @default("[]") // Scoped permissions (e.g., ["read:invoices", "write:orders"])
  usageCount Int       @default(0)
  quotaLimit Int? // Null means unlimited
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([prefix])
}

model App {
  id           String   @id @default(uuid())
  name         String   @unique
  label        String
  description  String?
  version      String
  category     String
  author       String?
  website      String?
  dependencies String?
  installed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  version     String   @default("1.0.0")
  isActive    Boolean  @default(false)
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModelDefinition {
  id           String            @id @default(uuid())
  moduleId     String?
  name         String            @unique
  label        String
  description  String?
  isSystem     Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  fields       FieldDefinition[]
  accessRights AccessRight[]
}

model FieldDefinition {
  id               String          @id @default(uuid())
  modelId          String
  name             String
  label            String
  type             FieldType
  required         Boolean         @default(false)
  targetModel      String?
  selectionOptions Json?
  model            ModelDefinition @relation(fields: [modelId], references: [id], onDelete: Cascade)
}

model AccessRight {
  id         String          @id @default(uuid())
  modelId    String
  role       String
  permRead   Boolean         @default(true)
  permWrite  Boolean         @default(false)
  permCreate Boolean         @default(false)
  permUnlink Boolean         @default(false)
  model      ModelDefinition @relation(fields: [modelId], references: [id], onDelete: Cascade)
}

model Record {
