}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model IdempotencyKey {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  status    String
  response  Json?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([expiresAt])
}

model GovernanceProfile {
  id                       String   @id @default(uuid())
  tenantId                 String   @unique
  criticalPotassium        Float    @default(6.0)
  criticalHemoglobin       Float    @default(7.0)
  criticalGlucose          Float    @default(500.0)
  warningPotassium         Float    @default(5.2)
  warningHemoglobin        Float    @default(10.0)
  warningGlucose           Float    @default(200.0)
  allowedVehicleIndustries String[] @default(["Logistics", "Manufacturing", "Construction"])
  fuelEfficiencyThreshold  Float    @default(1.15)
  tenant                   Tenant   @relation(fields: [tenantId], references: [id])
}

model UnitConversion {
  id        String  @id @default(uuid())
  tenantId  String
  fromUnit  String
  toUnit    String
  factor    Float
  productId String?
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, fromUnit, toUnit, productId])
}

model MobileDevice {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  deviceId     String
  deviceName   String?
  platform     String
  pushToken    String?
  isActive     Boolean  @default(true)
  lastSeenAt   DateTime @default(now())
  registeredAt DateTime @default(now())
  strictMode   Boolean  @default(false)
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, deviceId])
  @@index([userId])
}

model WebhookSecretRotation {
  id               String    @id @default(uuid())
  provider         String
  secret           String
  status           String    @default("Active")
  rotatedBy        String
  rotatedAt        DateTime  @default(now())
  graceExpiresAt   DateTime?
  retiredAt        DateTime?
  previousSecretId String?

  @@index([provider, status])
}

model WebhookDeadLetter {
  id                String    @id @default(uuid())
  provider          String
  event             String
  payload           Json
  tenantId          String?
  originalTimestamp DateTime
  jobId             String
  totalAttempts     Int
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([provider, resolvedAt])
}

model BackgroundJob {
  id             String    @id @default(uuid())
  idempotencyKey String    @unique
  tenantId       String
  userId         String
  type           String
  status         String    @default("Pending")
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  attempt        Int       @default(0)
  error          String?
  resultSummary  Json?
  createdAt      DateTime  @default(now())

  @@index([tenantId, type, status])
}

