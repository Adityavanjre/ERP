generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?
  fullName     String?
  avatarUrl    String?
  authProvider AuthProvider @default(Email)
  providerId   String?      // e.g., Google ID
  isSuperAdmin Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  auditLogs            AuditLog[]
  memberships  TenantUser[]
  productsCreated      Product[]    @relation("ProductCreator")
  productsUpdated      Product[]    @relation("ProductUpdater")
}

model Tenant {
  id              String                   @id @default(uuid())
  name            String
  slug            String                   @unique
  type            TenantType               @default(Retail)
  industry        String?
  businessType    String?
  isOnboarded     Boolean                  @default(false)
  plan            PlanType                 @default(Free)
  logoUrl         String?
  address         String?
  state           String?
  gstin           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  accounts        Account[]
  auditLogs       AuditLog[]
  boms            BillOfMaterial[]
  customers       Customer[]
  openingBalances CustomerOpeningBalance[]
  departments     Department[]
  employees       Employee[]
  invoices        Invoice[]
  journalEntries  JournalEntry[]
  machines        Machine[]
  opportunities   Opportunity[]
  orders          Order[]
  payments        Payment[]
  periodLocks     PeriodLock[]
  products        Product[]
  projects        Project[]
  purchaseOrders  PurchaseOrder[]
  suppliers       Supplier[]
  supplierOpeningBalances SupplierOpeningBalance[]
  tasks           Task[]
  users           TenantUser[]
  transactions    Transaction[]
  workOrders      WorkOrder[]
  warehouses      Warehouse[]
  stockMovements  StockMovement[]
  fixedAssets     FixedAsset[]
  comments        Comment[]
  apiKeys         ApiKey[]
  creditNotes     CreditNote[]
  debitNotes      DebitNote[]
  payrolls        Payroll[]
  leaves          Leave[]
  invoiceItems    InvoiceItem[]
  poItems         PurchaseOrderItem[]
  bomItems        BOMItem[]
  stockLocations  StockLocation[]
  cnItems         CreditNoteItem[]
  dnItems         DebitNoteItem[]
}

model PeriodLock {
  id           String    @id @default(uuid())
  tenantId     String
  month        Int
  year         Int
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  reopenedAt   DateTime?
  reopenReason String?
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month, year])
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     Role   @default(Biller)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Product {
  id                 String              @id @default(uuid())
  tenantId           String
  name               String
  sku                String
  description        String?
  price              Decimal             @default(0.00)
  costPrice          Decimal             @default(0.00)
  stock              Decimal             @default(0.00)
  category           String?
  tags               String?
  brand              String?
  manufacturer       String?
  weight             String?
  dimensions         String?
  minStockLevel      Decimal             @default(0.00)
  supplierName       String?
  isService          Boolean             @default(false)
  hsnCode            String?
  gstRate            Decimal             @default(0.00)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  isDeleted          Boolean             @default(false)
  barcode            String?
  skuAlias           String?
  bomAsMaterial      BOMItem[]
  bomAsFinished      BillOfMaterial[]
  invoiceItems       InvoiceItem[]
  orderItems         OrderItem[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  createdBy          User?               @relation("ProductCreator", fields: [createdById], references: [id])
  updatedBy          User?               @relation("ProductUpdater", fields: [updatedById], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  stockLocations     StockLocation[]
  stockMovements     StockMovement[]
  creditNoteItems    CreditNoteItem[]
  debitNoteItems     DebitNoteItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, category])
  @@index([tenantId, tags])
  @@index([tenantId, brand])
  @@index([tenantId, skuAlias])
  @@index([tenantId, hsnCode])

}

model Customer {
  id              String                   @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  company         String?
  address         String?
  state           String?
  gstin           String?
  status          CustomerStatus           @default(Lead)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  isDeleted       Boolean                  @default(false)
  userId          String?                  @unique
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances CustomerOpeningBalance[]
  invoices        Invoice[]
  opportunities   Opportunity[]
  projects        Project[]
  orders          Order[]
  payments        Payment[]
  creditNotes     CreditNote[]

  @@index([tenantId, email])
  @@index([tenantId, company])
  @@index([tenantId, status])
  @@index([tenantId, phone])
  @@index([tenantId, firstName, lastName])
}

model Opportunity {
  id            String    @id @default(uuid())
  tenantId      String
  title         String
  value         Decimal   @default(0.00)
  stage         Stage     @default(New)
  probability   Int       @default(0)
  expectedClose DateTime?
  customerId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  customer      Customer  @relation(fields: [customerId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String?
  total          Decimal     @default(0.00)
  status         OrderStatus @default(Draft)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  customer       Customer?   @relation(fields: [customerId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  items          OrderItem[]
  idempotencyKey String?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([tenantId, customerId, createdAt])
  @@unique([tenantId, idempotencyKey])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Decimal
  price     Decimal
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])

  @@index([orderId, productId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  resource  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
}

model BillOfMaterial {
  id              String      @id @default(uuid())
  tenantId        String
  name            String
  productId       String
  quantity        Int         @default(1)
  overheadRate    Decimal     @default(0.00)
  isOverheadFixed Boolean     @default(false)
  status          BOMStatus   @default(Active)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           BOMItem[]
  product         Product     @relation(fields: [productId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  workOrders      WorkOrder[]
}

model BOMItem {
  id          String         @id @default(uuid())
  tenantId    String
  bomId       String
  productId   String
  quantity    Decimal
  unit        String?
  isByproduct Boolean        @default(false)
  product     Product        @relation(fields: [productId], references: [id])
  bom         BillOfMaterial @relation(fields: [bomId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model WorkOrder {
  id               String          @id @default(uuid())
  tenantId         String
  orderNumber      String
  bomId            String
  quantity         Int
  producedQuantity Int             @default(0)
  scrapQuantity    Int             @default(0)
  startDate        DateTime?
  endDate          DateTime?
  status           WorkOrderStatus @default(Planned)
  priority         Priority        @default(Medium)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  idempotencyKey   String?
  completionLog    Json?
  bom              BillOfMaterial  @relation(fields: [bomId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, idempotencyKey])
}

model Machine {
  id              String        @id @default(uuid())
  tenantId        String
  name            String
  code            String
  type            String?
  status          MachineStatus @default(Idle)
  lastMaintenance DateTime?
  createdAt       DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
}

model Account {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  code         String
  type         AccountType
  balance      Decimal       @default(0.00)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, code])
}

model JournalEntry {
  id             String        @id @default(uuid())
  tenantId       String
  date           DateTime      @default(now())
  description    String
  reference      String?
  posted         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  transactions   Transaction[]
  invoice        Invoice?      @relation("InvoiceJournal")
  creditNote     CreditNote?   @relation("CreditNoteJournal")
  debitNote      DebitNote?    @relation("DebitNoteJournal")

  @@index([tenantId, date])
  @@index([reference])
}

model Transaction {
  id             String          @id @default(uuid())
  tenantId       String
  date           DateTime        @default(now())
  description    String
  amount         Decimal
  type           TransactionType
  accountId      String
  journalEntryId String?
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  account        Account         @relation(fields: [accountId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([accountId])
  @@index([journalEntryId])
  @@index([tenantId, accountId, date])
}

model Invoice {
  id                  String        @id @default(uuid())
  tenantId            String
  customerId          String?
  invoiceNumber       String
  issueDate           DateTime      @default(now())
  dueDate             DateTime
  totalAmount         Decimal
  amountPaid          Decimal       @default(0.00)
  totalTaxable        Decimal       @default(0.00)
  totalGST            Decimal       @default(0.00)
  totalCGST           Decimal       @default(0.00)
  totalSGST           Decimal       @default(0.00)
  totalIGST           Decimal       @default(0.00)
  status              InvoiceStatus @default(Unpaid)
  billingTimeSeconds  Int?
  isLocked            Boolean       @default(false)
  idempotencyKey      String?
  tallyExported       Boolean       @default(false)
  cancellationReason  String?
  isInterState        Boolean?      @default(false)
  journalEntryId      String?       @unique
  journalEntry        JournalEntry? @relation("InvoiceJournal", fields: [journalEntryId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  customer            Customer?     @relation(fields: [customerId], references: [id])
  tenant              Tenant        @relation(fields: [tenantId], references: [id])
  creditNotes         CreditNote[]
  items               InvoiceItem[]
  payments            Payment[]

  @@unique([tenantId, invoiceNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, issueDate])
  @@index([tenantId, status])
  @@index([invoiceNumber])
  @@index([tenantId, status, issueDate])
}

model InvoiceItem {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  productId     String
  productName   String   @default("")
  hsnCode       String?
  quantity      Decimal
  unitPrice     Decimal
  gstRate       Decimal
  taxableAmount Decimal
  gstAmount     Decimal
  cgstAmount    Decimal  @default(0.00)
  sgstAmount    Decimal  @default(0.00)
  igstAmount    Decimal  @default(0.00)
  totalAmount   Decimal
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([invoiceId, productId])
  @@index([tenantId])
}

model Payment {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String?
  supplierId     String?
  invoiceId      String?
  amount         Decimal
  date           DateTime    @default(now())
  mode           PaymentMode @default(Cash)
  reference      String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  isLocked       Boolean     @default(false)
  idempotencyKey String?
  tallyExported  Boolean     @default(false)
  invoice        Invoice?    @relation(fields: [invoiceId], references: [id])
  supplier       Supplier?   @relation(fields: [supplierId], references: [id])
  customer       Customer?   @relation(fields: [customerId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, customerId, date])
  @@unique([tenantId, idempotencyKey])
}

model CustomerOpeningBalance {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String
  amount      Decimal
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, customerId])
}

model Employee {
  id           String         @id @default(uuid())
  tenantId     String
  userId       String?        @unique
  employeeId   String
  firstName    String
  lastName     String
  email        String
  phone        String?
  jobTitle     String
  departmentId String?
  salary       Decimal        @default(0.00)
  joiningDate  DateTime       @default(now())
  status       EmployeeStatus @default(Active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  department   Department?    @relation(fields: [departmentId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  leaves       Leave[]
  payrolls     Payroll[]

  @@unique([tenantId, employeeId])
}

model Department {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  managerId String?
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]
}

model Payroll {
  id          String        @id @default(uuid())
  tenantId    String
  employeeId  String
  periodStart DateTime
  periodEnd   DateTime
  basicSalary Decimal
  bonuses     Decimal       @default(0.00)
  deductions  Decimal       @default(0.00)
  netPay      Decimal
  status      PayrollStatus @default(Draft)
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  employee    Employee      @relation(fields: [employeeId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model Leave {
  id         String      @id @default(uuid())
  tenantId   String
  employeeId String
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(Pending)
  createdAt  DateTime    @default(now())
  employee   Employee    @relation(fields: [employeeId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model Supplier {
  id             String                   @id @default(uuid())
  tenantId       String
  name           String
  contactName    String?
  email          String
  phone          String?
  address        String?
  state          String?
  gstin          String?
  category       String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  isDeleted      Boolean                  @default(false)
  userId         String?                  @unique
  payments       Payment[]
  purchaseOrders PurchaseOrder[]
  tenant         Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances SupplierOpeningBalance[]
  debitNotes     DebitNote[]
}

model SupplierOpeningBalance {
  id          String   @id @default(uuid())
  tenantId    String
  supplierId  String
  amount      Decimal
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, supplierId])
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  tenantId       String
  supplierId     String
  orderNumber    String
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  totalAmount    Decimal
  totalTaxable   Decimal             @default(0.00)
  totalGST       Decimal             @default(0.00)
  totalCGST      Decimal             @default(0.00)
  totalSGST      Decimal             @default(0.00)
  totalIGST      Decimal             @default(0.00)
  status         POStatus            @default(Draft)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  idempotencyKey String?
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  items          PurchaseOrderItem[]
  debitNotes     DebitNote[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, orderNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  tenantId        String
  purchaseOrderId String
  productId       String
  hsnCode         String?
  quantity        Decimal
  unitPrice       Decimal
  taxableAmount   Decimal       @default(0.00)
  gstRate         Decimal       @default(0.00)
  cgstAmount      Decimal       @default(0.00)
  sgstAmount      Decimal       @default(0.00)
  igstAmount      Decimal       @default(0.00)
  totalAmount     Decimal       @default(0.00)
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderId, productId])
  @@index([tenantId])
}

model CreditNote {
  id             String         @id @default(uuid())
  tenantId       String
  customerId     String
  invoiceId      String?
  noteNumber     String
  date           DateTime       @default(now())
  totalAmount    Decimal
  totalTaxable   Decimal        @default(0.00)
  totalGST       Decimal        @default(0.00)
  totalCGST      Decimal        @default(0.00)
  totalSGST      Decimal        @default(0.00)
  totalIGST      Decimal        @default(0.00)
  reason         String?
  journalEntryId String?        @unique
  journalEntry   JournalEntry?  @relation("CreditNoteJournal", fields: [journalEntryId], references: [id])
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id])
  customer       Customer       @relation(fields: [customerId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  idempotencyKey String?
  items          CreditNoteItem[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, noteNumber])
  @@index([tenantId, customerId])
}

model CreditNoteItem {
  id            String     @id @default(uuid())
  tenantId      String
  creditNoteId  String
  productId     String
  quantity      Decimal
  unitPrice     Decimal
  taxableAmount Decimal
  gstRate       Decimal
  gstAmount     Decimal @default(0.00)
  cgstAmount    Decimal @default(0.00)
  sgstAmount    Decimal @default(0.00)
  igstAmount    Decimal @default(0.00)
  totalAmount   Decimal
  product       Product    @relation(fields: [productId], references: [id])
  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id])
  tenant        Tenant     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model DebitNote {
  id              String         @id @default(uuid())
  tenantId        String
  supplierId      String
  purchaseOrderId String?
  noteNumber      String
  date            DateTime       @default(now())
  totalAmount     Decimal
  totalTaxable    Decimal        @default(0.00)
  totalGST        Decimal        @default(0.00)
  totalCGST       Decimal        @default(0.00)
  totalSGST       Decimal        @default(0.00)
  totalIGST       Decimal        @default(0.00)
  reason          String?
  journalEntryId  String?        @unique
  journalEntry    JournalEntry?  @relation("DebitNoteJournal", fields: [journalEntryId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  idempotencyKey  String?
  items           DebitNoteItem[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, noteNumber])
  @@index([tenantId, supplierId])
}

model DebitNoteItem {
  id            String    @id @default(uuid())
  tenantId      String
  debitNoteId   String
  productId     String
  quantity      Decimal
  unitPrice     Decimal
  taxableAmount Decimal
  gstRate       Decimal
  gstAmount     Decimal @default(0.00)
  cgstAmount    Decimal @default(0.00)
  sgstAmount    Decimal @default(0.00)
  igstAmount    Decimal @default(0.00)
  totalAmount   Decimal
  product       Product   @relation(fields: [productId], references: [id])
  debitNote     DebitNote @relation(fields: [debitNoteId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Project {
  id          String        @id @default(uuid())
  tenantId    String
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      ProjectStatus @default(Planned)
  priority    Priority      @default(Medium)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  tasks       Task[]
}

model Task {
  id          String     @id @default(uuid())
  projectId   String
  tenantId    String
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  status      TaskStatus @default(Todo)
  priority    Priority   @default(Medium)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])
}

model Warehouse {
  id        String          @id @default(uuid())
  tenantId  String
  name      String
  location  String?
  manager   String?
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  stocks    StockLocation[]
  movements StockMovement[]

  @@unique([tenantId, name])
}

model StockLocation {
  id          String    @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  quantity    Decimal   @default(0.00)
  notes       String    @default("")
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, productId, warehouseId, notes])
  @@index([tenantId])
}

enum MovementType {
  IN
  OUT
  TRANSFER
