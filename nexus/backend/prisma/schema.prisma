generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  passwordHash          String?
  fullName              String?
  avatarUrl             String?
  isSuperAdmin          Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  mfaEnabled            Boolean        @default(false)
  mfaSecret             String?
  mfaRecoveryCodes      String[]
  failedLoginAttempts   Int            @default(0)
  lockoutUntil          DateTime?
  authProvider          AuthProvider   @default(Email)
  providerId            String?
  tokenVersion          Int            @default(1)
  pushToken             String?
  auditLogs             AuditLog[]
  journalEntriesCreated JournalEntry[] @relation("JournalCreator")
  mobileDevices         MobileDevice[]
  productsCreated       Product[]      @relation("ProductCreator")
  productsUpdated       Product[]      @relation("ProductUpdater")
  memberships           TenantUser[]
}

model Tenant {
  id                      String                   @id @default(uuid())
  name                    String
  slug                    String                   @unique
  type                    TenantType               @default(Retail)
  plan                    PlanType                 @default(Free)
  logoUrl                 String?
  address                 String?
  state                   String?
  gstin                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  businessType            String?
  currency                String                   @default("INR")
  fyStartDay              Int                      @default(1)
  fyStartMonth            Int                      @default(4)
  industry                String?
  isOnboarded             Boolean                  @default(false)
  gracePeriodEndsAt       DateTime?
  planExpiresAt           DateTime?
  subscriptionStatus      SubscriptionStatus       @default(Active)
  suspendReason           String?
  suspendedAt             DateTime?
  razorpayCustomerId      String?
  razorpaySubscriptionId  String?
  downgradeRetryCount     Int                      @default(0)
  lastDowngradeRetryAt    DateTime?
  accessRights            AccessRight[]
  accounts                Account[]
  apiKeys                 ApiKey[]
  appointments            Appointment[]
  auditLogs               AuditLog[]
  bomItems                BOMItem[]
  boqs                    BOQ[]
  boqItems                BOQItem[]
  bankReconciliations     BankReconciliation[]
  bankStatements          BankStatement[]
  bankStatementLines      BankStatementLine[]
  boms                    BillOfMaterial[]
  billingEvents           BillingEvent[]
  comments                Comment[]
  creditNotes             CreditNote[]
  cnItems                 CreditNoteItem[]
  customers               Customer[]
  openingBalances         CustomerOpeningBalance[]
  debitNotes              DebitNote[]
  dnItems                 DebitNoteItem[]
  departments             Department[]
  emiSchedules            EMISchedule[]
  employees               Employee[]
  fieldDefinitions        FieldDefinition[]
  fixedAssets             FixedAsset[]
  fuelLogs                FuelLog[]
  governanceProfile       GovernanceProfile?
  hsnMasters              HsnMaster[]
  interestAccruals        InterestAccrual[]
  invoices                Invoice[]
  invoiceItems            InvoiceItem[]
  journalEntries          JournalEntry[]
  kycRecords              KYCRecord[]
  leaves                  Leave[]
  loans                   Loan[]
  loanInterestSlabs       LoanInterestSlab[]
  machines                Machine[]
  maintenanceSchedules    MaintenanceSchedule[]
  medicalRecords          MedicalRecord[]
  mobileDevices           MobileDevice[]
  modelDefinitions        ModelDefinition[]
  opportunities           Opportunity[]
  orders                  Order[]
  patients                Patient[]
  payments                Payment[]
  payrolls                Payroll[]
  periodLocks             PeriodLock[]
  pharmacyBatches         PharmacyBatch[]
  products                Product[]
  projects                Project[]
  purchaseOrders          PurchaseOrder[]
  poItems                 PurchaseOrderItem[]
  records                 Record[]
  retentionSchedules      RetentionSchedule[]
  routeBenchmarks         RouteBenchmark[]
  routeLogs               RouteLog[]
  siteInventories         SiteInventory[]
  stockLocations          StockLocation[]
  stockMovements          StockMovement[]
  suppliers               Supplier[]
  supplierOpeningBalances SupplierOpeningBalance[]
  tasks                   Task[]
  tdsLedgerMappings       TdsLedgerMapping[]
  tdsRules                TdsRule[]
  tdsTransactions         TdsTransaction[]
  users                   TenantUser[]
  transactions            Transaction[]
  unitConversions         UnitConversion[]
  vehicles                Vehicle[]
  warehouses              Warehouse[]
  warehousePrices         WarehousePrice[]
  workOrders              WorkOrder[]
  workflowDefinitions     WorkflowDefinition[]
  workflowNodes           WorkflowNode[]
  workflowTransitions     WorkflowTransition[]
}

model PeriodLock {
  id           String    @id @default(uuid())
  tenantId     String
  month        Int
  year         Int
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  reopenedAt   DateTime?
  reopenReason String?
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month, year])
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     Role   @default(Biller)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Product {
  id                 String              @id @default(uuid())
  tenantId           String
  name               String
  sku                String
  description        String?
  price              Decimal             @default(0.00)
  costPrice          Decimal             @default(0.00)
  stock              Decimal             @default(0.00)
  category           String?
  tags               String?
  brand              String?
  manufacturer       String?
  weight             String?
  dimensions         String?
  minStockLevel      Decimal             @default(0.00)
  supplierName       String?
  isService          Boolean             @default(false)
  hsnCode            String?
  gstRate            Decimal             @default(0.00)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  isDeleted          Boolean             @default(false)
  barcode            String?
  skuAlias           String?
  isGstOverride      Boolean             @default(false)
  shelfLifeDays      Int?
  baseUnit           String              @default("pcs")
  bomAsMaterial      BOMItem[]
  bomAsFinished      BillOfMaterial[]
  creditNoteItems    CreditNoteItem[]
  debitNoteItems     DebitNoteItem[]
  invoiceItems       InvoiceItem[]
  orderItems         OrderItem[]
  pharmacyBatches    PharmacyBatch[]
  createdBy          User?               @relation("ProductCreator", fields: [createdById], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  updatedBy          User?               @relation("ProductUpdater", fields: [updatedById], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  siteInventories    SiteInventory[]
  stockLocations     StockLocation[]
  stockMovements     StockMovement[]
  warehousePrices    WarehousePrice[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, name])
  @@index([tenantId, category])
  @@index([tenantId, tags])
  @@index([tenantId, brand])
  @@index([tenantId, skuAlias])
  @@index([tenantId, hsnCode])
}

model Customer {
  id              String                   @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  company         String?
  address         String?
  state           String?
  gstin           String?
  status          CustomerStatus           @default(Lead)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  isDeleted       Boolean                  @default(false)
  userId          String?                  @unique
  creditNotes     CreditNote[]
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances CustomerOpeningBalance[]
  invoices        Invoice[]
  loans           Loan[]
  opportunities   Opportunity[]
  orders          Order[]
  patient         Patient?
  payments        Payment[]
  projects        Project[]

  @@index([tenantId, email])
  @@index([tenantId, company])
  @@index([tenantId, status])
  @@index([tenantId, phone])
  @@index([tenantId, firstName, lastName])
}

model Opportunity {
  id            String    @id @default(uuid())
  tenantId      String
  title         String
  value         Decimal   @default(0.00)
  stage         Stage     @default(New)
  probability   Int       @default(0)
  expectedClose DateTime?
  customerId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer  @relation(fields: [customerId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String
  customerId     String?
  total          Decimal     @default(0.00)
  status         OrderStatus @default(Draft)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  idempotencyKey String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  items          OrderItem[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([tenantId, customerId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Decimal
  price     Decimal
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId, productId])
}

model AuditLog {
  id             String   @id @default(uuid())
  tenantId       String?
  userId         String?
  action         String
  resource       String
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())
  channel        String?
  correlationId  String?  @default(uuid())
  responseTimeMs Int?
  entryHash      String?
  prevHash       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([correlationId])
  @@index([action])
}

model BillOfMaterial {
  id              String      @id @default(uuid())
  tenantId        String
  name            String
  productId       String
  quantity        Int         @default(1)
  overheadRate    Decimal     @default(0.00)
  isOverheadFixed Boolean     @default(false)
  status          BOMStatus   @default(Active)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  correlationId   String?
  items           BOMItem[]
  product         Product     @relation(fields: [productId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  workOrders      WorkOrder[]

  @@index([tenantId])
  @@index([productId])
  @@index([correlationId])
}

model BOMItem {
  id          String         @id @default(uuid())
  bomId       String
  productId   String
  quantity    Decimal
  unit        String?
  isByproduct Boolean        @default(false)
  tenantId    String
  bom         BillOfMaterial @relation(fields: [bomId], references: [id])
  product     Product        @relation(fields: [productId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model WorkOrder {
  id               String          @id @default(uuid())
  tenantId         String
  orderNumber      String
  bomId            String
  quantity         Decimal
  startDate        DateTime?
  endDate          DateTime?
  status           WorkOrderStatus @default(Planned)
  priority         Priority        @default(Medium)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  producedQuantity Decimal         @default(0.00)
  scrapQuantity    Decimal         @default(0.00)
  completionLog    Json?
  correlationId    String?
  idempotencyKey   String?
  machineId        String?
  machineTimeHours Float?
  operatorName     String?
  bom              BillOfMaterial  @relation(fields: [bomId], references: [id])
  machine          Machine?        @relation(fields: [machineId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, orderNumber])
  @@index([tenantId, status, startDate])
  @@index([correlationId])
}

model Machine {
  id              String        @id @default(uuid())
  tenantId        String
  name            String
  code            String
  type            String?
  status          MachineStatus @default(Idle)
  lastMaintenance DateTime?
  createdAt       DateTime      @default(now())
  hourlyRate      Decimal?      @default(0.00)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  workOrders      WorkOrder[]

  @@index([tenantId])
  @@index([status])
}

model Account {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  code              String
  type              AccountType
  balance           Decimal            @default(0.00)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isActive          Boolean            @default(true)
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  bankStatements    BankStatement[]
  tdsLedgerMappings TdsLedgerMapping[]
  transactions      Transaction[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
}

model JournalEntry {
  id              String           @id @default(uuid())
  tenantId        String
  date            DateTime         @default(now())
  description     String
  reference       String?
  posted          Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  correlationId   String?
  createdById     String?
  creditNote      CreditNote?      @relation("CreditNoteJournal")
  debitNote       DebitNote?       @relation("DebitNoteJournal")
  fuelLog         FuelLog?
  interestAccrual InterestAccrual?
  invoice         Invoice?         @relation("InvoiceJournal")
  createdBy       User?            @relation("JournalCreator", fields: [createdById], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  loan            Loan?
  tdsTransaction  TdsTransaction?
  transactions    Transaction[]

  @@index([tenantId, date])
  @@index([correlationId])
  @@index([reference])
}

model Transaction {
  id              String               @id @default(uuid())
  tenantId        String
  date            DateTime             @default(now())
  description     String
  amount          Decimal
  type            TransactionType
  accountId       String
  journalEntryId  String?
  correlationId   String?
  reconciliations BankReconciliation[]
  account         Account              @relation(fields: [accountId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  tenant          Tenant               @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([accountId])
  @@index([journalEntryId])
  @@index([correlationId])
  @@index([tenantId, accountId, date])
}

model Invoice {
  id                 String        @id @default(uuid())
  tenantId           String
  customerId         String?
  invoiceNumber      String
  issueDate          DateTime      @default(now())
  dueDate            DateTime
  totalAmount        Decimal
  amountPaid         Decimal       @default(0.00)
  totalTaxable       Decimal       @default(0.00)
  totalGST           Decimal       @default(0.00)
  totalCGST          Decimal       @default(0.00)
  totalSGST          Decimal       @default(0.00)
  totalIGST          Decimal       @default(0.00)
  status             InvoiceStatus @default(Unpaid)
  billingTimeSeconds Int?
  isLocked           Boolean       @default(false)
  idempotencyKey     String?
  tallyExported      Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  cancellationReason String?
  correlationId      String?
  isInterState       Boolean?      @default(false)
  journalEntryId     String?       @unique
  projectId          String?
  creditNotes        CreditNote[]
  customer           Customer?     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  journalEntry       JournalEntry? @relation("InvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  items              InvoiceItem[]
  payments           Payment[]

  @@unique([tenantId, invoiceNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, issueDate])
  @@index([tenantId, status])
  @@index([correlationId])
  @@index([invoiceNumber])
  @@index([projectId])
  @@index([tenantId, status, issueDate])
}

model InvoiceItem {
  id            String   @id @default(uuid())
  invoiceId     String
  productId     String
  quantity      Decimal
  unitPrice     Decimal
  gstRate       Decimal
  taxableAmount Decimal
  gstAmount     Decimal
  totalAmount   Decimal
  createdAt     DateTime @default(now())
  cgstAmount    Decimal  @default(0.00)
  hsnCode       String?
  igstAmount    Decimal  @default(0.00)
  productName   String   @default("")
  sgstAmount    Decimal  @default(0.00)
  isGstOverride Boolean  @default(false)
  tenantId      String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([invoiceId, productId])
  @@index([tenantId])
}

model Payment {
  id             String          @id @default(uuid())
  tenantId       String
  customerId     String?
  supplierId     String?
  invoiceId      String?
  amount         Decimal
  date           DateTime        @default(now())
  mode           PaymentMode     @default(Cash)
  reference      String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isLocked       Boolean         @default(false)
  idempotencyKey String?
  tallyExported  Boolean         @default(false)
  correlationId  String?
  netAmount      Decimal?        @default(0.00)
  tdsAmount      Decimal?        @default(0.00)
  tdsSection     String?
  emiSchedule    EMISchedule?
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  tdsTransaction TdsTransaction?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, date])
  @@index([tenantId, customerId, date])
  @@index([correlationId])
}

model CustomerOpeningBalance {
  id            String   @id @default(uuid())
  tenantId      String
  customerId    String
  amount        Decimal
  date          DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  correlationId String?
  customer      Customer @relation(fields: [customerId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, customerId])
  @@index([correlationId])
}

model Employee {
  id           String         @id @default(uuid())
  tenantId     String
  userId       String?        @unique
  employeeId   String
  firstName    String
  lastName     String
  email        String
  phone        String?
  jobTitle     String
  departmentId String?
  salary       Decimal        @default(0.00)
  joiningDate  DateTime       @default(now())
  status       EmployeeStatus @default(Active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  appointments Appointment[]
  department   Department?    @relation(fields: [departmentId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  leaves       Leave[]
  payrolls     Payroll[]

  @@unique([tenantId, employeeId])
}

model Department {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  managerId String?
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]
}

model Payroll {
  id          String        @id @default(uuid())
  employeeId  String
  periodStart DateTime
  periodEnd   DateTime
  basicSalary Decimal
  bonuses     Decimal       @default(0.00)
  deductions  Decimal       @default(0.00)
  netPay      Decimal
  status      PayrollStatus @default(Draft)
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  tenantId    String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([employeeId, periodStart, periodEnd])
  @@index([tenantId, createdAt])
}

model Leave {
  id         String      @id @default(uuid())
  employeeId String
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(Pending)
  createdAt  DateTime    @default(now())
  tenantId   String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model Supplier {
  id                String                   @id @default(uuid())
  tenantId          String
  name              String
  contactName       String?
  email             String
  phone             String?
  address           String?
  state             String?
  gstin             String?
  category          String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  isDeleted         Boolean                  @default(false)
  userId            String?                  @unique
  defaultTdsSection String?
  pan               String?
  vendorType        VendorType               @default(Individual)
  debitNotes        DebitNote[]
  payments          Payment[]
  purchaseOrders    PurchaseOrder[]
  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  openingBalances   SupplierOpeningBalance[]
  tdsTransactions   TdsTransaction[]
}

model SupplierOpeningBalance {
  id            String   @id @default(uuid())
  tenantId      String
  supplierId    String
  amount        Decimal
  date          DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  correlationId String?
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, supplierId])
  @@index([correlationId])
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  tenantId       String
  supplierId     String
  orderNumber    String
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  totalAmount    Decimal
  status         POStatus            @default(Draft)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  totalCGST      Decimal             @default(0.00)
  totalGST       Decimal             @default(0.00)
  totalIGST      Decimal             @default(0.00)
  totalSGST      Decimal             @default(0.00)
  totalTaxable   Decimal             @default(0.00)
  idempotencyKey String?
  netAmount      Decimal?            @default(0.00)
  tdsAmount      Decimal?            @default(0.00)
  tdsSection     String?
  debitNotes     DebitNote[]
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  items          PurchaseOrderItem[]
  tdsTransaction TdsTransaction?

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, orderNumber])
  @@index([tenantId, status, expectedDate])
  @@index([tenantId, supplierId, orderDate])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal
  unitPrice       Decimal
  cgstAmount      Decimal       @default(0.00)
  gstRate         Decimal       @default(0.00)
  hsnCode         String?
  igstAmount      Decimal       @default(0.00)
  sgstAmount      Decimal       @default(0.00)
  taxableAmount   Decimal       @default(0.00)
  totalAmount     Decimal       @default(0.00)
  tenantId        String
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderId, productId])
  @@index([tenantId])
}

model CreditNote {
  id             String           @id @default(uuid())
  tenantId       String
  customerId     String
  invoiceId      String?
  noteNumber     String
  date           DateTime         @default(now())
  totalAmount    Decimal
  totalTaxable   Decimal          @default(0.00)
  totalGST       Decimal          @default(0.00)
  totalCGST      Decimal          @default(0.00)
  totalSGST      Decimal          @default(0.00)
  totalIGST      Decimal          @default(0.00)
  reason         String?
  journalEntryId String?          @unique
  correlationId  String?
  createdAt      DateTime         @default(now())
