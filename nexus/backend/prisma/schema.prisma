  correlationId  String?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  loan         Loan          @relation(fields: [loanId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([correlationId])
}

model KYCRecord {
  id                 String    @id @default(uuid())
  tenantId           String
  loanId             String    @unique
  documentType       String // Aadhar, PAN, VoterID
  documentNumber     String
  verificationStatus String    @default("Pending")
  verifiedAt         DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  loan   Loan   @relation(fields: [loanId], references: [id])
}

// --- Bank Reconciliation Statement (BRS) ---

model BankStatement {
  id             String   @id @default(uuid())
  tenantId       String
  accountId      String // Reference to Account (Bank Account)
  uploadDate     DateTime @default(now())
  startDate      DateTime
  endDate        DateTime
  openingBalance Decimal  @default(0.00)
  closingBalance Decimal  @default(0.00)

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  account   Account             @relation(fields: [accountId], references: [id])
  lines     BankStatementLine[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([tenantId, accountId])
}

model BankStatementLine {
  id          String          @id @default(uuid())
  tenantId    String
  statementId String
  date        DateTime
  description String
  amount      Decimal
  reference   String? // Cheque No / Reference No
  type        TransactionType // Debit / Credit (Bank's perspective)
  reconciled  Boolean         @default(false)

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  statement       BankStatement        @relation(fields: [statementId], references: [id])
  reconciliations BankReconciliation[]

  @@index([tenantId, statementId])
  @@index([date, amount])
}

model BankReconciliation {
  id              String   @id @default(uuid())
  tenantId        String
  transactionId   String // Reference to Transaction in GL
  statementLineId String // Reference to Bank Statement Line
  reconciledAt    DateTime @default(now())

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  transaction   Transaction       @relation(fields: [transactionId], references: [id])
  statementLine BankStatementLine @relation(fields: [statementLineId], references: [id])

  @@unique([tenantId, transactionId, statementLineId])
  @@index([tenantId, transactionId])
  @@index([tenantId, statementLineId])
}

model HsnMaster {
  id          String   @id @default(uuid())
  tenantId    String
  hsnCode     String
  description String?
  gstRate     Decimal
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, hsnCode])
  @@index([tenantId])
}
