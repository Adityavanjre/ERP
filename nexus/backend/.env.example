# 🐘 Klypso Nexus Engine - Environment Blueprint

# 🛡️ Core Infrastructure
PORT=3001
NODE_ENV=production

# 🐘 Database (Prisma / Supabase)
DATABASE_URL="postgresql://admin:password@localhost:5432/nexus_db?schema=public"

# 🔐 Security Forensic
JWT_SECRET="generate-a-high-entropy-string-here"
JWT_EXPIRES_IN="24h"

# 🌐 Gateway/Proxy Configuration
# The base path where the frontend is served (for redirects)
FRONTEND_URL="https://klypso.in/portal"
BACKEND_URL="https://klypso.in/portal/api"

# 📊 Analytics & Kernel
# Enable/Disable specific high-load aggregation services
KERNEL_STATS_ENABLED=true
AUDIT_LOG_LEVEL=verbose

# 🏢 Email Service (Internal Notifications)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=xxx

# 🚀 Performance
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
CACHE_MAX_ITEMS=1000
