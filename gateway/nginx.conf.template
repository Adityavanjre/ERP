# 🚪 Klypso Gateway (Render Nginx Config)
# Standardized for Render Docker Environment - Klypso Hardened 🛡️🚀

server {
    listen 80 default_server;
    server_name klypso.in www.klypso.in localhost;

    # Resolver for Public DNS (Google)
    resolver 8.8.8.8 valid=30s;

    # 🔗 Debug Headers (Internal Diagnostics)
    add_header X-Gateway-Version "Klypso-Standard-1.0";

    # 🎨 Klypso ERP Portal (Frontend)
    # Higher priority prefix match (^~) to beat the root / block
    location ^~ /portal {
        proxy_pass https://${KLYPSO_FRONTEND_HOST};
        proxy_ssl_server_name on;
        proxy_set_header Host ${KLYPSO_FRONTEND_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Standard Proxy Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # 🐘 Klypso Engine API
    location ^~ /portal/api {
        # Strip /portal/api and prepend /api
        proxy_pass https://${KLYPSO_BACKEND_HOST}/api;
        proxy_ssl_server_name on;
        proxy_set_header Host ${KLYPSO_BACKEND_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 🏢 Agency API
    location ^~ /api/agency {
        # Strip /api/agency and proxy to root
        proxy_pass https://${AGENCY_BACKEND_HOST};
        proxy_ssl_server_name on;
        proxy_set_header Host ${AGENCY_BACKEND_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 🚀 Klypso Agency Website (Root & Catch-all)
    location / {
        proxy_pass https://${AGENCY_VIEWER_HOST}; 
        proxy_ssl_server_name on;
        proxy_set_header Host ${AGENCY_VIEWER_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
